# Pearl miner defaults. Copy to config.env before install, or edit
# /etc/pearl/pearl.env after install.

# Default payout wallet.
WALLET=prl1pvgs56cfqzkfzqjgm6npgw3j5jc3w8ra2uk6ysdum58qpzmnanzmsfs4kjz

# Official AlphaPool Pearl miner binary.
MINER_URL=https://pearl.alphapool.tech/downloads/alpha-miner
INSTALL_DIR=/opt/pearl

# Mining settings.
DIFF=524288
WORKER_PREFIX=

# Use relay/VPS tunnel by default:
# local miner -> 127.0.0.1:15566 -> VPS -> sg1.alphapool.tech:5566
USE_RELAY=1
RELAY_USER=root
RELAY_HOST=203.55.176.251
RELAY_LOCAL_PORT=15566
RELAY_REMOTE_HOST=sg1.alphapool.tech
RELAY_REMOTE_PORT=5566

# Direct pool fallback when USE_RELAY=0.
POOL_HOST=sg1.alphapool.tech
POOL_PORT=5566

# Optional dashboard heartbeat. Leave MONITOR_TOKEN blank if not used.
MONITOR_URL=http://203.55.176.251:8080
MONITOR_TOKEN=
MACHINE_ID=

# Watchdog tuning.
CHECK_INTERVAL=30
IDLE_THRESHOLD=20
IDLE_LIMIT=2
STARTUP_GRACE=60
STALE_SHARE_SECONDS=240

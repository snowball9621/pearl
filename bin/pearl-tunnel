#!/usr/bin/env bash
set -euo pipefail

# shellcheck disable=SC1091
. /usr/local/bin/pearl-env

PID_FILE="$RUN_DIR/tunnel.pid"
LOG_FILE="$LOG_DIR/tunnel.log"

tcp_ok() {
  timeout 3 bash -c "</dev/tcp/127.0.0.1/${RELAY_LOCAL_PORT}" >/dev/null 2>&1
}

alive() {
  [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

start() {
  mkdir -p "$LOG_DIR" "$RUN_DIR"
  if [ "$USE_RELAY" != "1" ]; then
    echo "relay disabled"
    return 0
  fi
  if tcp_ok; then
    echo "tunnel ok: 127.0.0.1:${RELAY_LOCAL_PORT}"
    return 0
  fi
  if alive; then
    kill "$(cat "$PID_FILE")" 2>/dev/null || true
    sleep 1
  fi
  nohup ssh \
    -o BatchMode=yes \
    -o StrictHostKeyChecking=accept-new \
    -o ServerAliveInterval=20 \
    -o ServerAliveCountMax=3 \
    -o ExitOnForwardFailure=yes \
    -N \
    -L "127.0.0.1:${RELAY_LOCAL_PORT}:${RELAY_REMOTE_HOST}:${RELAY_REMOTE_PORT}" \
    "${RELAY_USER}@${RELAY_HOST}" \
    >> "$LOG_FILE" 2>&1 &
  echo $! > "$PID_FILE"
  sleep 2
  tcp_ok && echo "tunnel started: 127.0.0.1:${RELAY_LOCAL_PORT}" || {
    echo "tunnel failed; check $LOG_FILE"
    exit 1
  }
}

stop() {
  if alive; then
    kill "$(cat "$PID_FILE")" 2>/dev/null || true
  fi
  rm -f "$PID_FILE"
}

status() {
  if tcp_ok; then
    echo "tunnel: ok 127.0.0.1:${RELAY_LOCAL_PORT} -> ${RELAY_REMOTE_HOST}:${RELAY_REMOTE_PORT}"
  else
    echo "tunnel: down"
    return 1
  fi
}

case "${1:-start}" in
  start) start ;;
  stop) stop ;;
  restart) stop; start ;;
  status) status ;;
  *) echo "usage: pearl-tunnel [start|stop|restart|status]"; exit 2 ;;
esac

#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="${PEARL_CONFIG:-/etc/pearl/pearl.env}"
if [ -f "$CONFIG_FILE" ]; then
  # shellcheck disable=SC1090
  . "$CONFIG_FILE"
fi

WALLET="${WALLET:-prl1pvgs56cfqzkfzqjgm6npgw3j5jc3w8ra2uk6ysdum58qpzmnanzmsfs4kjz}"
INSTALL_DIR="${INSTALL_DIR:-/opt/pearl}"
DIFF="${DIFF:-524288}"
WORKER_PREFIX="${WORKER_PREFIX:-}"

USE_RELAY="${USE_RELAY:-1}"
RELAY_USER="${RELAY_USER:-root}"
RELAY_HOST="${RELAY_HOST:-203.55.176.251}"
RELAY_LOCAL_PORT="${RELAY_LOCAL_PORT:-15566}"
RELAY_REMOTE_HOST="${RELAY_REMOTE_HOST:-sg1.alphapool.tech}"
RELAY_REMOTE_PORT="${RELAY_REMOTE_PORT:-5566}"

POOL_HOST="${POOL_HOST:-sg1.alphapool.tech}"
POOL_PORT="${POOL_PORT:-5566}"

MONITOR_URL="${MONITOR_URL:-http://203.55.176.251:8080}"
MONITOR_TOKEN="${MONITOR_TOKEN:-}"
MACHINE_ID="${MACHINE_ID:-}"

CHECK_INTERVAL="${CHECK_INTERVAL:-30}"
IDLE_THRESHOLD="${IDLE_THRESHOLD:-20}"
IDLE_LIMIT="${IDLE_LIMIT:-2}"
STARTUP_GRACE="${STARTUP_GRACE:-60}"
STALE_SHARE_SECONDS="${STALE_SHARE_SECONDS:-240}"

LOG_DIR="/var/log/pearl"
RUN_DIR="/var/run/pearl"

export WALLET INSTALL_DIR DIFF WORKER_PREFIX
export USE_RELAY RELAY_USER RELAY_HOST RELAY_LOCAL_PORT RELAY_REMOTE_HOST RELAY_REMOTE_PORT
export POOL_HOST POOL_PORT MONITOR_URL MONITOR_TOKEN MACHINE_ID
export CHECK_INTERVAL IDLE_THRESHOLD IDLE_LIMIT STARTUP_GRACE STALE_SHARE_SECONDS
export LOG_DIR RUN_DIR
